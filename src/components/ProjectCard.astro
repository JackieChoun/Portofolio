---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  image: string;
  description: string;
  technologies: { name: string; icon: string }[];
  url: string;
  status?: string;
}

const {
  title,
  image,
  description,
  technologies,
  url,
  status = "En ligne",
} = Astro.props;
---

<article
  class="group bg-[#252526] border border-zinc-700 rounded-xl overflow-hidden hover:border-blue-500 transition-all duration-300"
>
  <div class="relative overflow-hidden">
    <img
      src={image}
      alt={title}
      loading="lazy"
      class="w-full h-64 object-cover transition duration-500 group-hover:scale-105"
    />

    <span
      class="absolute top-4 right-4 bg-green-600 text-white text-xs px-2 py-1 rounded"
    >
      {status}
    </span>
  </div>

  <div class="p-6">
    <h3 class="text-2xl font-semibold mb-4">
      {title}
    </h3>

    <div class="flex flex-wrap gap-4 mb-4">
      {
        technologies.map((tech) => (
          <div class="flex items-center gap-2">
            <Icon name={tech.icon} class="w-5 h-5" />
            <span class="text-sm">{tech.name}</span>
          </div>
        ))
      }
    </div>

    <p class="text-zinc-300 mb-6">
      {description}
    </p>

    <a
      href={url}
      target="_blank"
      class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-500 rounded transition"
    >
      Voir le projet →
    </a>
  </div>
</article>
