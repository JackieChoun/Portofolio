---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  image: ImageMetadata;
  description: string;
  technologies: { name: string; icon: string }[];
  url: string;
  status?: string;
}

const {
  title,
  image,
  description,
  technologies,
  url,
  status = "En ligne",
} = Astro.props;
---

<article
  class="group bg-[#252526] border border-zinc-700 rounded-xl overflow-hidden hover:border-orange-700 transition-all duration-300"
>
  <div class="relative overflow-hidden">
    <Image
      src={image}
      alt={title}
      loading="lazy"
      class="w-full h-52 sm:h-64 object-cover transition duration-500 group-hover:scale-105"
    />

    <span
      class="absolute top-3 right-3 sm:top-4 sm:right-4 bg-green-600 text-white text-xs px-2 py-1 rounded"
    >
      {status}
    </span>
  </div>

  <div class="p-5 sm:p-6">
    <h3 class="text-xl sm:text-2xl font-semibold mb-4">
      {title}
    </h3>

    <div class="flex flex-wrap gap-x-4 gap-y-2 mb-4">
      {
        technologies.map((tech) => (
          <div class="flex items-center gap-2">
            <Icon name={tech.icon} class="w-4 h-4 sm:w-5 sm:h-5" />
            <span class="text-xs sm:text-sm">{tech.name}</span>
          </div>
        ))
      }
    </div>

    <p class="text-sm sm:text-base text-zinc-300 mb-6">
      {description}
    </p>

    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center w-full sm:w-auto px-4 py-2 bg-orange-700 hover:bg-orange-600 rounded transition"
    >
      Voir le projet →
    </a>
  </div>
</article>
